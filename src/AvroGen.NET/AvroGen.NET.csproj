<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>0.3.4</Version>
    <Authors>iiitpux</Authors>
    <Company>iiitpux</Company>
    <Description>Library for automatic generation of C# classes from Avro schemas stored in Schema Registry</Description>
    <PackageProjectUrl>https://github.com/iiitpux/AvroGen.NET</PackageProjectUrl>
    <RepositoryUrl>https://github.com/iiitpux/AvroGen.NET.git</RepositoryUrl>
    <PackageTags>avro;schema-registry;kafka;confluent;code-generation</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <IncludeBuildOutput>true</IncludeBuildOutput>
    <BuildOutputTargetFolder>build</BuildOutputTargetFolder>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Apache.Avro" Version="1.11.3" />
    <PackageReference Include="Confluent.SchemaRegistry" Version="2.3.0" />
    <PackageReference Include="Confluent.SchemaRegistry.Serdes.Avro" Version="2.3.0" />
    <PackageReference Include="Microsoft.Build.Framework" Version="17.8.3" PrivateAssets="all" />
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="17.8.3" PrivateAssets="all" />
    <PackageReference Include="System.CodeDom" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="build\**" Pack="true" PackagePath="build" />
  </ItemGroup>

  <Target Name="CopyBuildFiles" AfterTargets="Build">
    <ItemGroup>
      <BuildFiles Include="$(MSBuildThisFileDirectory)build\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(BuildFiles)" DestinationFolder="$(OutputPath)build\%(RecursiveDir)" />
  </Target>

</Project>
